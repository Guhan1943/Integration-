DATABASE_URL=sqlite:///./db.sqlite3
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://127.0.0.1:8000/api/hrms/callback/

# Optional defaults for bamboo if you want to keep fixed credentials in env.
# Usually api_key and subdomain are passed per request.
BAMBOO_API_KEY=
BAMBOO_SUBDOMAIN=
